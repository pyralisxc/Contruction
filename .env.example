# Copy this file to .env and fill in any environment-specific values.
# Do NOT commit your .env file with real secrets.

# Server
PORT=3002
NODE_ENV=development
DEBUG=false

# Home Depot adapter mode: mock | unofficial | live
# - mock: use local mock data (safe default)
# - unofficial: use prototype scrapers (fragile, respect TOS)
# - live: use partner API (requires credentials)
HOMEDPOT_MODE=mock

# Per-store / adapter rate limits
HOMEDPOT_RATE_LIMIT_PER_MIN=30
STORE_RATE_LIMIT_WINDOW_MS=60000
STORE_RATE_LIMIT_MAX=60

# Redis (optional) - enable to persist shareable carts and caching
# Example: redis://localhost:6379
REDIS_URL=

# Cache TTLs (ms)
STORE_CACHE_TTL_MS=600000

# Enable unofficial scrapers in development ONLY. Must be explicitly set to true.
# Set to 'true' on your local dev machine to allow `HOMEDPOT_MODE=unofficial`.
ALLOW_UNOFFICIAL=false

# Admin API key for debugging routes (do NOT use in public deployments)
# Example: ADMIN_API_KEY=local-secret-REPLACE
ADMIN_API_KEY=

# If you plan to use a partner 'live' adapter, set the partner credentials here (example)
# HOMEDPOT_MODE=live
# HOMEDPOT_API_KEY=
